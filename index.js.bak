/**
 * noxarianet store вЂ” WhatsApp Bot v4.0 (NATIVE FLOW BUTTONS)
 * Tombol nyata terlihat di semua akun WA (personal & business)
 */

const {
    default: makeWASocket,
    useMultiFileAuthState,
    DisconnectReason,
    fetchLatestBaileysVersion,
    makeCacheableSignalKeyStore,
    proto,
    generateWAMessageFromContent
} = require("@whiskeysockets/baileys");
const { createClient } = require('@supabase/supabase-js');
const qrcode = require('qrcode-terminal');
const axios = require('axios');
const pino = require('pino');
const WebSocket = require('ws');
const os = require('os');
const fs = require('fs');
require('dotenv').config();

// в•ђв•ђв•ђ ANTI-CRASH: Tangkap semua unhandled rejection agar bot tidak exit в•ђв•ђв•ђ
process.on('unhandledRejection', (reason) => {
    console.error('вљ пёЏ Unhandled Rejection (ditangkap):', reason?.message || reason);
});
process.on('uncaughtException', (err) => {
    console.error('вљ пёЏ Uncaught Exception (ditangkap):', err.message);
});

// в•ђв•ђв•ђ SUPABASE в•ђв•ђв•ђ
let supabase;
if (process.env.SUPABASE_URL && process.env.SUPABASE_KEY) {
    supabase = createClient(process.env.SUPABASE_URL, process.env.SUPABASE_KEY, {
        realtime: { transport: WebSocket }
    });
    console.log('вњ… Supabase configured');
} else {
    console.warn('вљ пёЏ SUPABASE belum dikonfigurasi di .env');
}

const GROUP_NAME_KEYWORD = 'noxarianet';
const ADMIN_NUMBER = '6285936603517';

let supabaseSubscribed = false;
let currentSock = null;
let cachedGroupId = null;
let targetGroupId = '120363424077781671@g.us';
const notifiedOrderIds = new Set();
let pollingStarted = false; // Guard: cegah multiple interval saat reconnect

// в”Ђв”Ђв”Ђ HELPER: Format nomor WA ke JID Baileys в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
function formatWaJid(waNumber) {
    let num = (waNumber || '').toString().replace(/\D/g, '');
    if (!num) return null;
    if (num.startsWith('0')) num = '62' + num.slice(1);
    else if (!num.startsWith('62')) num = '62' + num;
    return `${num}@s.whatsapp.net`;
}

// в”Ђв”Ђв”Ђ HELPER: Format licenses dari account_details ke teks WA в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
function formatLicenses(licenses) {
    if (!licenses || licenses.length === 0) {
        return '_Detail akun tidak tersedia. Hubungi admin._';
    }
    return licenses.map((lic, i) => {
        if (typeof lic === 'string') return `${i + 1}. ${lic}`;
        const lines = Object.entries(lic)
            .filter(([, v]) => v !== null && v !== undefined && v !== '')
            .map(([k, v]) => `   вЂў ${k}: *${v}*`);
        return `рџ”ђ *Akun ${i + 1}:*\n${lines.join('\n')}`;
    }).join('\n\n');
}

// в”Ђв”Ђв”Ђ HELPER: Resolve ID grup target (dengan caching) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
async function resolveGroupId(sock) {
    if (cachedGroupId) return cachedGroupId;
    try {
        const groups = await sock.groupFetchAllParticipating();
        const tg = Object.values(groups).find(g =>
            g.subject.toLowerCase().includes(GROUP_NAME_KEYWORD)
        );
        if (tg) {
            cachedGroupId = tg.id;
            return cachedGroupId;
        }
    } catch (e) {
        console.error('вљ пёЏ resolveGroupId error:', e.message);
    }
    return targetGroupId;
}

async function startBot() {
    try {
        const { state, saveCreds } = await useMultiFileAuthState('auth_info_baileys');
        const { version } = await fetchLatestBaileysVersion();

        const sock = makeWASocket({
            version,
            logger: pino({ level: 'silent' }),
            auth: {
                creds: state.creds,
                keys: makeCacheableSignalKeyStore(state.keys, pino({ level: 'silent' })),
            },
            browser: ["noxarianet Bot", "Safari", "3.0"],
            syncFullHistory: false,
        });
        currentSock = sock;

        sock.ev.on('creds.update', saveCreds);

        const getSendOptions = (quotedMsg) => {
            let options = {};
            if (quotedMsg) {
                // Cegah quote jika dari @lid karena memicu error 406 (not-acceptable)
                const participant = quotedMsg.key.participant || quotedMsg.key.remoteJid || '';
                if (participant.includes('@lid')) {
                    options.ephemeralExpiration = 86400; // Manual ephemeral untuk grup disappearing
                } else {
                    options.quoted = quotedMsg;
                }
            }
            return options;
        };

        // в•ђв•ђв•ђ HELPER: KIRIM TEKS BIASA в•ђв•ђв•ђ
        const sendText = async (jid, text, quotedMsg = null) => {
            try {
                await sock.sendMessage(jid, { text }, getSendOptions(quotedMsg));
                console.log(`вњ… Pesan terkirim ke ${jid}`);
            } catch (err) {
                console.error('вќЊ Error kirim pesan:', err.message);
            }
        };

        // в•ђв•ђв•ђ HELPER: KIRIM GAMBAR в•ђв•ђв•ђ
        const sendMessage = async (jid, text, imageUrl = null, quotedMsg = null) => {
            try {
                if (imageUrl) {
                    try {
                        const res = await axios.get(imageUrl, { responseType: 'arraybuffer', timeout: 10000 });
                        await sock.sendMessage(jid, { image: Buffer.from(res.data), caption: text }, getSendOptions(quotedMsg));
                    } catch {
                        await sendText(jid, text, quotedMsg);
                    }
                } else {
                    await sendText(jid, text, quotedMsg);
                }
            } catch (err) {
                console.error('вќЊ Error sendMessage:', err.message);
            }
        };

        const startTime = Date.now();

        // в•ђв•ђв•ђ HELPER: KIRIM MENU PREMIUM (VERSION 4.6 - GROUP STABLE) в•ђв•ђв•ђ
        const sendInteractiveMenu = async (jid, quotedMsg = null) => {
            const now = new Date().toLocaleString('id-ID', { timeZone: 'Asia/Jakarta' });
            const uptime = Date.now() - startTime;
            const uh = Math.floor(uptime / 3600000);
            const um = Math.floor((uptime % 3600000) / 60000);

            const menuTeks = 
                `*в”Ђв”Ђв”ЂгЂЊ NOXARIANET STORE гЂЌв”Ђв”Ђв”Ђ*\n` +
                `*Digital Assistant Menu*\n` +
                `в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n\n` +
                `*Noxarianet Virtual Assistant* рџ’њ\n` +
                `> Layanan Otomatis Aktif 24/7\n\n` +
                `  вЂў Bot    : noxarianet Bot v4.6\n` +
                `  вЂў Status : рџџў Online & Public\n` +
                `  вЂў Uptime : ${uh}j ${um}m\n\n` +
                `*в”Ђв”Ђв”ЂгЂЊ LAYANAN гЂЌв”Ђв”Ђв”Ђ*\n` +
                `рџ›’ *.order*  вЂ” Cara Order\n` +
                `рџ‘¤ *.owner*  вЂ” Kontak Owner\n` +
                `рџ“ў *.lapor*  вЂ” Kirim Laporan\n\n` +
                `*в”Ђв”Ђв”ЂгЂЊ SISTEM гЂЌв”Ђв”Ђв”Ђ*\n` +
                `рџЏ“ *.ping*     вЂ” Status Bot\n` +
                `вЏі *.runtime*  вЂ” Uptime\n` +
                `рџ“¦ *.cekdb*    вЂ” Statistik DB\n` +
                `рџ–ҐпёЏ *.panel*    вЂ” Status Server\n\n` +
                `в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ\n` +
                `_Ketik perintah di atas untuk memulai_\n` +
                `*В© 2026 noxarianet.web.id*`;

            try {
                await sock.sendMessage(jid, { text: menuTeks }, getSendOptions(quotedMsg));
                console.log(`вњ… Stable menu v4.6 terkirim ke ${jid}`);
            } catch (err) {
                console.error('вљ пёЏ Gagal kirim menu:', err.message);
            }
        };

        // в•ђв•ђв•ђ EKSEKUSI PILIHAN MENU в•ђв•ђв•ђ
        const handleMenuAction = async (btnId, remoteJid, senderNum, m = null) => {
            switch (btnId) {
                case 'btn_order':
                    await sendText(remoteJid,
                        "рџ›’ *CARA PEMESANAN DI NOXARIANET*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n" +
                        "1пёЏвѓЈ Kunjungi: *www.noxarianet.web.id*\n" +
                        "2пёЏвѓЈ Pilih produk & varian\n" +
                        "3пёЏвѓЈ Isi data pribadi dengan benar\n" +
                        "4пёЏвѓЈ Selesaikan pembayaran\n" +
                        "5пёЏвѓЈ Terima notifikasi otomatis\n" +
                        "6пёЏвѓЈ Produk dikirim 1вЂ“5 menit\n" +
                        "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nвњ… Mudah, cepat, & terpercaya!", m
                    );
                    break;
                case 'btn_owner':
                    await sendText(remoteJid,
                        "рџ‘¤ *OWNER NOXARIANET*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n" +
                        `рџ“± WhatsApp: https://wa.me/${ADMIN_NUMBER}\n` +
                        "рџ’ј Hubungi untuk penawaran spesial!\n" +
                        "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ", m
                    );
                    break;
                case 'btn_ping':
                    await sendText(remoteJid, "рџЏ“ *PONG!*\nвњ… Bot noxarianet aktif & berjalan normal!", m);
                    break;
                case 'btn_runtime': {
                    const up = Date.now() - startTime;
                    const h = Math.floor(up / 3600000);
                    const mTime = Math.floor((up % 3600000) / 60000);
                    const s = Math.floor((up % 60000) / 1000);
                    await sendText(remoteJid,
                        `вЏі *BOT RUNTIME*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nрџџў Aktif: *${h}h ${mTime}m ${s}s*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ`, m
                    );
                    break;
                }
                case 'btn_cekdb':
                    try {
                        if (!supabase) throw new Error('Supabase tidak dikonfigurasi');
                        const { data: orders, error } = await supabase.from('orders').select('*');
                        if (error) throw error;
                        const total = orders?.length || 0;
                        const pending = orders?.filter(o => o.status === 'pending').length || 0;
                        const done = orders?.filter(o => o.status === 'completed').length || 0;
                        const today = orders?.filter(o => new Date(o.timestamp).toDateString() === new Date().toDateString()).length || 0;
                        await sendText(remoteJid,
                            `рџ“¦ *STATISTIK DATABASE*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nрџ“Љ Total: *${total}*\nвЏі Pending: *${pending}*\nвњ… Selesai: *${done}*\nрџ“… Hari Ini: *${today}*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ`, m
                        );
                    } catch (err) {
                        await sendText(remoteJid, `вќЊ Error DB: ${err.message}`, m);
                    }
                    break;
                case 'btn_panel': {
                    const tot = os.totalmem(), free = os.freemem(), used = tot - free;
                    const pct = ((used / tot) * 100).toFixed(2);
                    const up2 = os.uptime();
                    await sendText(remoteJid,
                        `рџ–ҐпёЏ *STATUS SERVER*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n` +
                        `рџ’ѕ RAM Total: ${(tot/1024/1024/1024).toFixed(2)} GB\n` +
                        `рџ“€ Terpakai: ${(used/1024/1024/1024).toFixed(2)} GB (${pct}%)\n` +
                        `рџ†“ Bebas: ${(free/1024/1024/1024).toFixed(2)} GB\n` +
                        `рџ”§ CPU Cores: ${os.cpus().length}\n` +
                        `вЏ±пёЏ Uptime: ${Math.floor(up2/3600)}h ${Math.floor((up2%3600)/60)}m\n` +
                        `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nрџџў *ONLINE & STABIL*`, m
                    );
                    break;
                }
                case 'btn_lapor':
                    await sendText(remoteJid,
                        "рџ“ў *KIRIM LAPORAN*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nKetik:\n\n*.lapor <pesan Anda>*\n\nContoh:\n*.lapor Pesanan saya belum diproses*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ", m
                    );
                    break;
                default:
                    await sendInteractiveMenu(remoteJid, m);
            }
        };

        // в•ђв•ђв•ђ KONEKSI в•ђв•ђв•ђ
        sock.ev.on('connection.update', async (update) => {
            const { connection, lastDisconnect, qr } = update;
            if (qr) {
                console.clear();
                console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
                console.log('в•‘  рџ”ђ SCAN QR CODE WHATSAPP ANDA в•‘');
                console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
                qrcode.generate(qr, { small: true });
            }
            if (connection === 'close') {
                const statusCode = lastDisconnect?.error?.output?.statusCode;
                const shouldReconnect = statusCode !== DisconnectReason.loggedOut;
                console.log(`вќЊ Koneksi terputus (Status: ${statusCode}). Reconnect: ${shouldReconnect}`);
                
                if (shouldReconnect) {
                    cachedGroupId = null;
                    setTimeout(() => startBot(), 3000);
                } else {
                    console.log('вљ пёЏ Sesi logout / invalid. Menghapus folder auth dan restart untuk QR baru...');
                    try {
                        if (fs.existsSync('auth_info_baileys')) {
                            fs.rmSync('auth_info_baileys', { recursive: true, force: true });
                        }
                    } catch (e) {
                        console.error('вљ пёЏ Gagal menghapus folder sesi:', e.message);
                    }
                    setTimeout(() => startBot(), 3000);
                }
            } else if (connection === 'open') {
                console.clear();
                console.log('\nв•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—');
                console.log('в•‘  вњ… BOT NOXARIANET AKTIF v4.0  в•‘');
                console.log('в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n');
                try {
                    const groups = await sock.groupFetchAllParticipating();
                    Object.values(groups).forEach((g, i) => {
                        console.log(`   ${i + 1}. ${g.subject} (ID: ${g.id})`);
                        if (g.subject.toLowerCase().includes(GROUP_NAME_KEYWORD)) {
                            cachedGroupId = g.id;
                            console.log(`   вњ… Grup target otomatis di-cache: ${g.id}`);
                        }
                    });
                } catch (e) { console.log('вљ пёЏ Error fetch grup: ' + e.message); }
                console.log('\nрџЋЇ Bot siap menerima pesan!\n');
            }
        });

        // в•ђв•ђв•ђ MEMBER BARU (PREMIUM GREETING) в•ђв•ђв•ђ
        sock.ev.on('group-participants.update', async (anu) => {
            try {
                if (anu.action === 'add') {
                    const meta = await sock.groupMetadata(anu.id);
                    if (meta.subject.toLowerCase().includes(GROUP_NAME_KEYWORD) || anu.id === targetGroupId) {
                        for (let num of anu.participants) {
                            const greeting = 
                                `в•”в•ђв•ђв•ђв•ђ  *WELCOME MEMBER*  в•ђв•ђв•ђв•ђв•—\n` +
                                `в•‘      *New Member Joined*      в•‘\n` +
                                `в•љв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ќ\n\n` +
                                `Halo @${num.split('@')[0]} рџ‘‹\n\n` +
                                `Selamat datang di komunitas *${meta.subject}*! вњЁ\n\n` +
                                `Saya adalah asisten digital di grup ini. Ketik *.noxa* untuk melihat fitur layanan kami atau bantuan pesanan.\n\n` +
                                `*Happy Shopping!* рџ›ЌпёЏрџ’њ\n\n` +
                                `В© 2026 noxarianet store`;

                            try {
                                await sock.sendMessage(anu.id, {
                                    text: greeting,
                                    mentions: [num]
                                }, { timeout: 5000 });
                            } catch (e) {
                                console.error('вљ пёЏ Gagal greeting:', e.message);
                            }
                        }
                    }
                }
            } catch (err) { console.error('вљ пёЏ Error group-participants:', err.message); }
        });

        // в•ђв•ђв•ђ HANDLER PESAN MASUK в•ђв•ђв•ђ
        sock.ev.on('messages.upsert', async (chatUpdate) => {
            try {
                const m = chatUpdate.messages[0];
                if (!m.message || m.key.fromMe) return;

                const remoteJid = m.key.remoteJid;
                const isGroup = remoteJid.endsWith('@g.us');
                
                // рџ”“ MODE FULL PUBLIC: Bot merespon di manapun (Grup & Japri)
                const senderNum = isGroup ? m.key.participant : remoteJid;

                // в”Ђв”Ђв”Ђ UNWRAP PESAN (Support Disappearing Messages di Grup) в”Ђв”Ђв”Ђ
                let msgData = m.message;
                if (msgData?.ephemeralMessage) {
                    msgData = msgData.ephemeralMessage.message;
                }
                if (msgData?.viewOnceMessageV2) {
                    msgData = msgData.viewOnceMessageV2.message;
                }

                // в”Ђв”Ђв”Ђ Tangkap respons native flow button в”Ђв”Ђв”Ђ
                const nativeFlow = msgData?.interactiveResponseMessage?.nativeFlowResponseMessage;
                if (nativeFlow) {
                    const params = JSON.parse(nativeFlow.paramsJson || '{}');
                    const btnId = params.id;
                    console.log(`рџЋЇ Native Flow Response: ${btnId} dari ${senderNum}`);
                    await handleMenuAction(btnId, remoteJid, senderNum, m);
                    return;
                }

                // в”Ђв”Ђв”Ђ Tangkap respons list message в”Ђв”Ђв”Ђ
                const listRowId = msgData?.listResponseMessage?.singleSelectReply?.selectedRowId;
                if (listRowId) {
                    console.log(`рџЋЇ List Response: ${listRowId} dari ${senderNum}`);
                    await handleMenuAction(listRowId, remoteJid, senderNum, m);
                    return;
                }

                const messageContent =
                    msgData?.conversation ||
                    msgData?.extendedTextMessage?.text ||
                    msgData?.imageMessage?.caption || 
                    msgData?.videoMessage?.caption || '';

                if (!messageContent) return;
                const msg = messageContent.toLowerCase().trim();

                console.log(`рџ“© ${isGroup ? '[GRUP]' : '[JAPRI]'} ${senderNum}: "${messageContent}"`);

                if (msg.includes('@noxarianet')) { await sendInteractiveMenu(remoteJid, m); return; }
                if (!msg.startsWith('.')) return;

                const command = msg.slice(1).trim().split(' ')[0];
                console.log(`рџЋЇ Command: .${command}`);

                switch (command) {
                    case 'noxa':
                        await sendInteractiveMenu(remoteJid, m); break;
                    default:
                        // Do not respond to unknown commands
                        break;
                }
            } catch (err) { console.error('вќЊ Error handler:', err.message); }
        });

        // в•ђв•ђв•ђ SUPABASE REALTIME в•ђв•ђв•ђ
        if (!supabaseSubscribed && supabase) {
            supabaseSubscribed = true;
            console.log('рџ“Ў Subscribing Supabase Realtime...');

            // в”Ђв”Ђ Channel 1: INSERT вЂ” Order baru masuk, notif admin grup в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            supabase
                .channel('public:orders:insert')
                .on('postgres_changes', { event: 'INSERT', schema: 'public', table: 'orders' }, async (payload) => {
                    const s = currentSock;
                    if (!s) return;
                    const order = payload.new;
                    console.log(`\nрџ”” ORDER BARU (INSERT): ${order.id}`);

                    let notif = `вњЁ *ORDER BARU MASUK!* вњЁ\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                    notif += `рџ†” ID: *${order.id}*\nрџ“¦ Produk: *${order.product}*\n`;
                    notif += `рџ’Ћ Varian: ${order.variant || '-'}\n`;
                    notif += `рџ’° Harga: *Rp ${Number(order.price || 0).toLocaleString('id-ID')}*\n`;
                    notif += `рџ’і Metode: ${order.payment_method || '-'}\n`;
                    notif += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\nрџ‘¤ *PEMBELI*\n`;
                    notif += `рџ“± WA: *${order.wa_number}*\nрџ“§ Email: ${order.email || '-'}\n`;
                    notif += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                    notif += `вЏ° ${new Date(order.timestamp || Date.now()).toLocaleString('id-ID')}\n`;
                    notif += `вЏі _Menunggu pembayaran..._`;

                    try {
                        const groupId = await resolveGroupId(s);
                        await sendText(groupId, notif);
                    } catch (err) { console.error('вќЊ Error notif INSERT ke grup:', err.message); }
                })
                .subscribe(status => console.log(`рџ“Ў Realtime [INSERT]: ${status}`));

            // в”Ђв”Ђ Channel 2: UPDATE вЂ” Perubahan status order в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
            supabase
                .channel('public:orders:update')
                .on('postgres_changes', { event: 'UPDATE', schema: 'public', table: 'orders' }, async (payload) => {
                    const s = currentSock;
                    if (!s) return;
                    const order = payload.new;
                    const newStatus = order.status;
                    const notifKey = `${order.id}:${newStatus}`;

                    // Idempotency вЂ” jangan kirim notif yang sama dua kali
                    if (notifiedOrderIds.has(notifKey)) return;
                    notifiedOrderIds.add(notifKey);

                    console.log(`\nрџ”„ ORDER UPDATE [Realtime]: ${order.id} в†’ ${newStatus}`);
                    const waJid = formatWaJid(order.wa_number);

                    // в”Ђ PROCESSING: Pembayaran terkonfirmasi в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
                    if (newStatus === 'PROCESSING') {
                        if (waJid) {
                            await sendText(waJid,
                                `вљ™пёЏ *PEMBAYARAN BERHASIL вЂ” SEDANG DIPROSES!*\n` +
                                `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n` +
                                `Halo Kak! рџ‘‹\n\n` +
                                `вњ… Pembayaran order *${order.id}* sudah kami terima!\n` +
                                `рџ“¦ Produk: *${order.product}*\n` +
                                `рџ’Ћ Varian: ${order.variant || '-'}\n\n` +
                                `вљ™пёЏ Akun sedang disiapkan secara otomatis...\n` +
                                `вЏі Estimasi: *1вЂ“5 menit*\n\n` +
                                `Kami akan langsung kirim detail akun ke sini ya Kak! рџ™Џрџ’њ`
                            );
                        }
                        return;
                    }

                    // в”Ђ COMPLETED: Kirim detail akun ke user в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
                    if (newStatus === 'COMPLETED') {
                        const licenses = (order.account_details || {}).licenses || [];
                        const akunText = formatLicenses(licenses);

                        if (waJid) {
                            let msg = `рџЋ‰ *PESANAN SELESAI!* рџЋ‰\n`;
                            msg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            msg += `рџ†” Order: *${order.id}*\n`;
                            msg += `рџ“¦ Produk: *${order.product}*\n`;
                            msg += `рџ’Ћ Varian: ${order.variant || '-'}\n`;
                            msg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            msg += `рџ”‘ *DETAIL AKUN ANDA:*\n\n`;
                            msg += `${akunText}\n\n`;
                            msg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            msg += `вљ пёЏ _Jangan share akun ini ke orang lain!_\n`;
                            msg += `рџ’њ Terima kasih sudah berbelanja di *noxarianet store*!\n`;
                            msg += `рџ“ў Tinggalkan ulasan positif ya Kak рџ™Џ`;
                            await sendText(waJid, msg);
                        }

                        // Notif ringkas ke grup admin
                        try {
                            const groupId = await resolveGroupId(s);
                            let adminMsg = `вњ… *ORDER COMPLETED*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            adminMsg +        // в•ђв•ђв•ђ POLLING DATABASE (FALLBACK jika Realtime mati) в•ђв•ђв•ђ
        // Guard: SATU interval total meski startBot() dipanggil ulang saat reconnect.
        // Polling menggunakan currentSock langsung agar selalu pakai koneksi aktif.
        if (!pollingStarted) {
            pollingStarted = true;
            const POLLING_WINDOW_MS = 60 * 60 * 1000; // 1 jam

            setInterval(async () => {
                if (!supabase || !currentSock) return;
                // Skip jika koneksi belum ter-autentikasi (mencegah "Connection Closed")
                if (!currentSock.user) return;

                try {
                    const since = new Date(Date.now() - POLLING_WINDOW_MS).toISOString();

                    const { data: activeOrders, error } = await supabase
                        .from('orders')
                        .select('*')
                        .in('status', ['PROCESSING', 'COMPLETED', 'FAILED'])
                        .gt('timestamp', since)
                        .order('timestamp', { ascending: true });

                    if (error || !activeOrders || activeOrders.length === 0) return;

                    for (const order of activeOrders) {
                        const notifKey = `${order.id}:${order.status}`;
                        if (notifiedOrderIds.has(notifKey)) continue;

                        // Cek koneksi lagi sebelum setiap pengiriman
                        if (!currentSock?.user) {
                            console.log('вљ пёЏ [POLLING] Koneksi terputus saat loop, berhenti.');
                            break;
                        }

                        notifiedOrderIds.add(notifKey);
                        console.log(`\nрџ”” [POLLING] ${order.id} вЂ” status: ${order.status}`);
                        const waJid = formatWaJid(order.wa_number);

                        // Helper pakai currentSock langsung (bukan closure sock lama)
                        const sendPoll = async (jid, text) => {
                            await currentSock.sendMessage(jid, { text });
                        };

                        try {
                            if (order.status === 'PROCESSING') {
                                if (waJid) {
                                    await sendPoll(waJid,
                                        `вљ™пёЏ *PEMBAYARAN BERHASIL вЂ” SEDANG DIPROSES!*\n` +
                                        `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n` +
                                        `Halo Kak! рџ‘‹\n\n` +
                                        `вњ… Pembayaran order *${order.id}* sudah kami terima!\n` +
                                        `рџ“¦ Produk: *${order.product}*\n` +
                                        `рџ’Ћ Varian: ${order.variant || '-'}\n\n` +
                                        `вљ™пёЏ Akun sedang disiapkan secara otomatis...\n` +
                                        `вЏі Estimasi: *1вЂ“5 menit*\n\n` +
                                        `Kami akan langsung kirim detail akun ke sini ya Kak! рџ™Џрџ’њ`
                                    );
                                }

                            } else if (order.status === 'COMPLETED') {
                                const licenses = (order.account_details || {}).licenses || [];
                                const akunText = formatLicenses(licenses);
                                if (waJid) {
                                    let msg = `рџЋ‰ *PESANAN SELESAI!* рџЋ‰\n`;
                                    msg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                                    msg += `рџ†” Order: *${order.id}*\n`;
                                    msg += `рџ“¦ Produk: *${order.product}*\n`;
                                    msg += `рџ’Ћ Varian: ${order.variant || '-'}\n`;
                                    msg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                                    msg += `рџ”‘ *DETAIL AKUN ANDA:*\n\n`;
                                    msg += `${akunText}\n\n`;
                                    msg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                                    msg += `вљ пёЏ _Jangan share akun ini ke orang lain!_\n`;
                                    msg += `рџ’њ Terima kasih sudah berbelanja di *noxarianet store*!\n`;
                                    msg += `рџ“ў Tinggalkan ulasan positif ya Kak рџ™Џ`;
                                    await sendPoll(waJid, msg);
                                }
                                try {
                                    const groupId = await resolveGroupId(currentSock);
                                    let adminMsg = `вњ… *ORDER COMPLETED*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                                    adminMsg += `рџ†” *${order.id}*\n`;
                                    adminMsg += `рџ“¦ ${order.product} вЂ” ${order.variant || '-'}\n`;
                                    adminMsg += `рџ“± ${order.wa_number}\n`;
                                    adminMsg += `вЏ° ${new Date().toLocaleString('id-ID')}`;
                                    await sendPoll(groupId, adminMsg);
                                } catch (err) { console.error('вќЊ Error notif COMPLETED polling (grup):', err.message); }

                            } else if (order.status === 'FAILED') {
                                try {
                                    const groupId = await resolveGroupId(currentSock);
                                    let failMsg = `вљ пёЏ *ORDER GAGAL!* вљ пёЏ\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                                    failMsg += `рџ†” ID: *${order.id}*\n`;
                                    failMsg += `рџ“¦ ${order.product} вЂ” ${order.variant || '-'}\n`;
                                    failMsg += `рџ“± WA: ${order.wa_number}\n`;
                                    failMsg += `вќЊ Error: _${order.error_message || 'Unknown error'}_\n`;
                                    failMsg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                                    failMsg += `рџ› пёЏ *Perlu pengecekan manual!*`;
                                    await sendPoll(groupId, failMsg);
                                } catch (err) { console.error('вќЊ Error notif FAILED polling (grup):', err.message); }

                                if (waJid) {
                                    await sendPoll(waJid,
                                        `вќЊ *MAAF, PESANAN GAGAL DIPROSES*\n` +
                                        `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n` +
                                        `Halo Kak, ada kendala pada pesanan *${order.id}*.\n\n` +
                                        `Tim kami segera menangani masalah ini.\n` +
                                        `Mohon hubungi admin untuk bantuan:\n` +
                                        `рџ“± https://wa.me/${ADMIN_NUMBER}\n` +
                                        `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n` +
                                        `Mohon maaf atas ketidaknyamanannya рџ™Џ`
                                    );
                                }
                            }

                        } catch (sendErr) {
                            // Gagal kirim вЂ” hapus dari set agar polling berikutnya bisa retry
                            notifiedOrderIds.delete(notifKey);
                            console.error(`вќЊ [POLLING] Gagal kirim notif ${order.id}, akan retry:`, sendErr.message);
                        }
                    }
                } catch (err) {
                    // Silently ignore to prevent log spam
                }
            }, 10000); // Cek setiap 10 detik
        }Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            msg += `вљ пёЏ _Jangan share akun ini ke orang lain!_\n`;
                            msg += `рџ’њ Terima kasih sudah berbelanja di *noxarianet store*!\n`;
                            msg += `рџ“ў Tinggalkan ulasan positif ya Kak рџ™Џ`;
                            await sendText(waJid, msg);
                        }
                        try {
                            const groupId = await resolveGroupId(currentSock);
                            let adminMsg = `вњ… *ORDER COMPLETED*\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            adminMsg += `рџ†” *${order.id}*\n`;
                            adminMsg += `рџ“¦ ${order.product} вЂ” ${order.variant || '-'}\n`;
                            adminMsg += `рџ“± ${order.wa_number}\n`;
                            adminMsg += `вЏ° ${new Date().toLocaleString('id-ID')}`;
                            await sendText(groupId, adminMsg);
                        } catch (err) { console.error('вќЊ Error notif COMPLETED polling:', err.message); }

                    } else if (order.status === 'FAILED') {
                        try {
                            const groupId = await resolveGroupId(currentSock);
                            let failMsg = `вљ пёЏ *ORDER GAGAL!* вљ пёЏ\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            failMsg += `рџ†” ID: *${order.id}*\n`;
                            failMsg += `рџ“¦ ${order.product} вЂ” ${order.variant || '-'}\n`;
                            failMsg += `рџ“± WA: ${order.wa_number}\n`;
                            failMsg += `вќЊ Error: _${order.error_message || 'Unknown error'}_\n`;
                            failMsg += `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n`;
                            failMsg += `рџ› пёЏ *Perlu pengecekan manual!*`;
                            await sendText(groupId, failMsg);
                        } catch (err) { console.error('вќЊ Error notif FAILED polling:', err.message); }

                        const waJidFail = formatWaJid(order.wa_number);
                        if (waJidFail) {
                            await sendText(waJidFail,
                                `вќЊ *MAAF, PESANAN GAGAL DIPROSES*\n` +
                                `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n` +
                                `Halo Kak, ada kendala pada pesanan *${order.id}*.\n\n` +
                                `Tim kami segera menangani masalah ini.\n` +
                                `Mohon hubungi admin untuk bantuan:\n` +
                                `рџ“± https://wa.me/${ADMIN_NUMBER}\n` +
                                `в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\n` +
                                `Mohon maaf atas ketidaknyamanannya рџ™Џ`
                            );
                        }
                    }
                }
            } catch (err) {
                // Silently ignore to prevent log spam
            }
        }, 10000); // Cek setiap 10 detik

    } catch (err) {
        console.error('\nвќЊ ERROR FATAL:', err.message);
        setTimeout(() => startBot(), 5000);
    }
}

